@echo off
chcp 65001 >nul
REM ============================================================
REM 서버 수동 종료 스크립트
REM PC를 완전히 정리하거나, 서버를 재시작하고 싶을 때 사용.
REM 평소 작업 종료 시에는 UI 창만 닫으면 되고, 이 파일은 쓰지 않아도 됩니다.
REM ============================================================

echo main.exe 프로세스를 종료합니다.
taskkill /F /IM main.exe
if errorlevel 1 (
    echo 실행 중인 main.exe 가 없거나 종료에 실패했습니다.
) else (
    echo 서버 종료 완료.
)
pause
